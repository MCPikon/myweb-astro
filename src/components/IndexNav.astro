---
import { getI18N, getI18NPath } from "@/i18n";

const currentLocale = Astro.currentLocale ?? "es";
const i18n = getI18N({ currentLocale });

const cvLang = currentLocale === "en" ? "/cv_en.pdf" : "/cv.pdf";
const cvPath =
  "https://gppfcbvhaqtribpz.public.blob.vercel-storage.com" + cvLang;
const langPath = currentLocale === "en" ? "/" : "/en";
---

<div id="hamburger" class="relative z-50">
  <div class="fixed -right-2.5 top-[50svh] translate-y-[-50%] rotate-270">
    <button
      id="menu-button"
      aria-expanded="false"
      aria-controls="menu-content"
      class="glass-btn font-bold px-4 py-1 rounded-t-xl cursor-pointer transition-all active:scale-95"
    >
      <span id="btn-text" class="flex items-center gap-2">
        <svg
          id="icon-svg"
          class="size-4 icon-left transition-transform duration-300"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path id="svg-path" d="M9 6l6 6-6 6"></path>
        </svg>
      </span>
    </button>
  </div>

  <div
    id="menu-content"
    class="fixed inset-0 glass-overlay -z-10 invisible opacity-0 transition-all duration-500 ease-in-out"
  >
    <nav class="h-full flex items-center justify-center">
      <div class="glass-panel">
        <ul
          class="flex flex-col text-4xl font-bold text-center space-y-6 p-10 list-none"
        >
          <li>
            <a
              class="nav-link glass-link block px-6 py-2 rounded-2xl"
              href={getI18NPath(currentLocale, "")}
              title="home"
              aria-label={i18n.INDEX_AND_PAGE_NAV_LINK_1}
            >
              {i18n.INDEX_AND_PAGE_NAV_LINK_1}
            </a>
          </li>
          <li>
            <a
              class="nav-link glass-link block px-6 py-2 rounded-2xl"
              href={getI18NPath(currentLocale, "projects")}
              title="projects"
              aria-label={i18n.INDEX_NAV_LINK_2}
            >
              {i18n.INDEX_NAV_LINK_2}
            </a>
          </li>
          <li>
            <a
              class="nav-link glass-link block px-6 py-2 rounded-2xl"
              href={getI18NPath(currentLocale, "#about")}
              title="about"
              aria-label={i18n.INDEX_AND_PAGE_NAV_LINK_3}
            >
              {i18n.INDEX_AND_PAGE_NAV_LINK_3}
            </a>
          </li>
          <li>
            <a
              class="nav-link glass-link block px-6 py-2 rounded-2xl"
              href={getI18NPath(currentLocale, "#experience")}
              title="experience"
              aria-label={i18n.INDEX_AND_PAGE_NAV_LINK_4}
            >
              {i18n.INDEX_AND_PAGE_NAV_LINK_4}
            </a>
          </li>

          <li
            class="pt-6 mt-2 border-t border-(--color-border) flex flex-col gap-4"
          >
            <a
              class="nav-link glass-link-sm flex items-center justify-center gap-3 text-2xl px-6 py-2 rounded-2xl"
              target="_blank"
              href={cvPath}
              title="cv"
              aria-label={i18n.INDEX_AND_PAGE_NAV_LINK_5}
            >
              <svg
                class="size-6 shrink-0 transform-gpu [vector-effect:non-scaling-stroke] [shape-rendering:geometricPrecision]"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"
                ></path>
                <path d="M14 2v5h5"></path>
                <path d="M12 12v6"></path>
                <path d="m9 15 3 3 3-3"></path>
                <path d="M8.5 10h7"></path>
              </svg>
              {i18n.INDEX_AND_PAGE_NAV_LINK_5}
            </a>

            <a
              class="nav-link glass-link-sm flex items-center justify-center gap-3 text-2xl px-6 py-2 rounded-2xl"
              href={langPath}
              title="language"
              aria-label={i18n.INDEX_NAV_LINK_6}
            >
              <svg
                class="size-6 shrink-0 transform-gpu [vector-effect:non-scaling-stroke]"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                <path d="M4 5h7"></path><path d="M7 4c0 4.846 0 7 .5 8"></path>
                <path
                  d="M10 8.5c0 2.286 -2 4.5 -3.5 4.5s-2.5 -1.135 -2.5 -2c0 -2 1 -3 3 -3s5 .57 5 2.857c0 1.524 -.667 2.571 -2 3.143"
                ></path>
                <path d="M12 20l4 -9l4 9"></path><path d="M19.1 18h-6.2"></path>
              </svg>
              {i18n.INDEX_NAV_LINK_6}
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>
</div>

<style>
  /* ── Liquid Glass: botón lateral ── */
  .glass-btn {
    background: color-mix(in srgb, var(--color-primary) 35%, transparent);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
    border-bottom: none;
    box-shadow:
      0 4px 24px color-mix(in srgb, var(--color-primary) 20%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 30%, transparent),
      inset 0 -1px 0 var(--color-glass-highlight);
    color: var(--color-text-strong);
    text-shadow: 0 1px 2px var(--color-text-shadow);
    transition: all 0.3s ease;
  }

  .glass-btn:hover {
    background: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow:
      0 6px 32px color-mix(in srgb, var(--color-primary) 35%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 45%, transparent),
      inset 0 -1px 0 var(--color-glass-highlight);
    border-color: color-mix(
      in srgb,
      var(--color-primary) 50%,
      var(--color-text-strong)
    );
  }

  /* ── Overlay del menú ── */
  .glass-overlay {
    background: var(--color-overlay);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    overflow: hidden;
  }

  /* ── Panel central de cristal ── */
  .glass-panel {
    background: var(--color-glass-bg);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border-radius: 32px;
    border: 1px solid var(--color-glass-border);
    box-shadow:
      0 32px 80px var(--color-shadow),
      0 0 60px var(--color-glass-shadow),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 25%, transparent),
      inset 0 -1px 0 var(--color-glass-highlight);
    position: relative;
    overflow: hidden;
  }

  /* Reflejo superior tipo cristal */
  .glass-panel::before {
    content: "";
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--color-primary) 60%, transparent),
      transparent
    );
  }

  /* Brillo lateral izquierdo */
  .glass-panel::after {
    content: "";
    position: absolute;
    top: 5%;
    left: 0;
    width: 1px;
    height: 40%;
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in srgb, var(--color-primary) 40%, transparent),
      transparent
    );
  }

  /* ── Links principales ── */
  .glass-link {
    color: var(--color-text);
    text-shadow: 0 2px 8px var(--color-text-shadow);
    transition: all 0.25s ease;
    position: relative;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
  }

  .glass-link:hover {
    color: var(--color-text-strong);
    background: color-mix(in srgb, var(--color-primary) 18%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
    box-shadow:
      0 8px 24px color-mix(in srgb, var(--color-primary) 20%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 30%, transparent);
    text-shadow: 0 0 20px
      color-mix(in srgb, var(--color-primary) 60%, transparent);
    transform: translateY(-1px);
  }

  /* ── Links secundarios (CV / idioma) ── */
  .glass-link-sm {
    color: var(--color-text-muted);
    transition: all 0.25s ease;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
  }

  .glass-link-sm:hover {
    color: var(--color-text-strong);
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow:
      0 4px 16px color-mix(in srgb, var(--color-primary) 20%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 20%, transparent);
    transform: translateY(-1px);
  }

  /* ── Estado abierto ── */
  #menu-content.open {
    visibility: visible;
    opacity: 1;
  }

  /* ── Animación de entrada del panel ── */
  #menu-content .glass-panel {
    transform: scale(0.92) translateY(12px);
    transition:
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.4s ease;
    opacity: 0;
  }

  #menu-content.open .glass-panel {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .icon-left {
    transform: rotate(270deg);
  }

  .icon-right {
    transform: rotate(90deg);
  }
</style>

<script>
  function setupMenu() {
    const btn = document.getElementById(
      "menu-button",
    ) as HTMLButtonElement | null;
    const menu = document.getElementById("menu-content");
    const panel = menu?.querySelector(".glass-panel");
    const icon = document.getElementById("icon-svg");
    const links = document.querySelectorAll(".nav-link");
    const header = document.querySelector(".header-section");

    const isOpen = () => menu?.classList.contains("open") ?? false;

    const open = () => {
      menu?.classList.add("open");
      btn?.setAttribute("aria-expanded", "true");
      icon?.classList.remove("icon-left");
      icon?.classList.add("icon-right");
      header?.classList.remove("z-50");
      header?.classList.add("z-10");
      document.body.style.overflow = "hidden";
      // Añadir estado al historial para capturar el botón "atrás" en móvil
      history.pushState({ menuOpen: true }, "");
    };

    const close = () => {
      menu?.classList.remove("open");
      btn?.setAttribute("aria-expanded", "false");
      icon?.classList.add("icon-left");
      icon?.classList.remove("icon-right");
      header?.classList.remove("z-10");
      header?.classList.add("z-50");
      document.body.style.overflow = "";
    };

    const toggle = () => (isOpen() ? close() : open());

    // Botón de abrir/cerrar
    btn?.addEventListener("click", toggle);

    // Cerrar al pulsar un enlace
    links.forEach((link) => link.addEventListener("click", close));

    // Cerrar al pulsar fuera del panel
    menu?.addEventListener("click", (e) => {
      if (panel && !panel.contains(e.target as Node)) close();
    });

    // Cerrar con tecla Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen()) close();
    });

    // Cerrar con el botón "atrás" del navegador/móvil
    window.addEventListener("popstate", (e) => {
      if (isOpen()) close();
    });
  }

  setupMenu();
  document.addEventListener("astro:after-swap", setupMenu);
</script>
