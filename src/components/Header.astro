---
import { EMAIL, INSTAGRAM_URL, GITHUB_URL, LINKEDIN_URL } from "@/utils/constants";

import MailIcon from "./icons/Mail.astro"
import InstagramIcon from "./icons/Instagram.astro"
import GitHubIcon from "./icons/GitHub.astro"
import LinkedinIcon from "./icons/Linkedin.astro"
---

<section
  class='header-section fixed left-1/2 right-auto top-5 z-50 mx-auto mt-3 mb-6 w-[min(1200px,calc(100%-2rem))] -translate-x-1/2 transition-[width,margin,top,transform] duration-[500ms] ease-[cubic-bezier(0.65,0,0.35,1)] max-md:mt-2 max-md:mb-5 max-md:w-[calc(100%-1.5rem)] max-md:duration-[420ms]'
>
  <nav
    class='glass-header nav-content relative flex w-full items-center justify-between overflow-hidden rounded-full px-4 py-2 transition-[border-radius,background,border-color,box-shadow] duration-[600ms] ease-[cubic-bezier(0.68,-0.55,0.265,1.55)] max-md:duration-[420ms]'
  >
    <div class="flex items-center gap-2">
      <a
        aria-label={EMAIL}
        href={"mailto:" + EMAIL}
        class="email-link-mobile flex lg:hidden p-2 rounded-lg glass-icon transition-all"
      >
        <MailIcon class="mail-icon text-white/70 size-5 transition-all" />
      </a>
      <a
        aria-label={EMAIL}
        href={"mailto:" + EMAIL}
        class="email-link-desktop hidden lg:flex flex-row items-center justify-center gap-2 px-3 py-2 rounded-xl glass-link-header transition-all"
      >
        <div class="p-2 rounded-lg glass-icon transition-all flex items-center justify-center">
          <MailIcon class="mail-icon text-white/70 size-5 transition-all" />
        </div>
        <h3 class="text-sm text-white/80 font-medium transition-all email-text">
          {EMAIL}
        </h3>
      </a>
    </div>

    <div class="flex items-center gap-1">
      <a
        aria-label="Instagram"
        target="_blank"
        href={INSTAGRAM_URL}
        class="p-2 rounded-lg glass-icon transition-all"
      >
        <InstagramIcon class="fill-white/70 size-5 transition-all hover:fill-white" />
      </a>
      <a
        aria-label="Github"
        target="_blank"
        href={GITHUB_URL}
        class="p-2 rounded-lg glass-icon transition-all"
      >
        <GitHubIcon class="fill-white/70 size-5 transition-all hover:fill-white" />
      </a>
      <a
        aria-label="Linkedin"
        target="_blank"
        href={LINKEDIN_URL}
        class="p-2 rounded-lg glass-icon transition-all"
      >
        <LinkedinIcon class="fill-white/70 size-5 transition-all hover:fill-white" />
      </a>
    </div>
  </nav>
</section>

<script>
  import { initHeaderScroll } from '@/utils/headerScroll'

  initHeaderScroll()
</script>

<style>
  .header-section {
    will-change: width, top, transform;
  }

  .header-section.scrolled {
    margin: 0;
    width: 100%;
    top: 0;
    padding: 0;
  }


  .glass-header {
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.3),
      0 0 40px color-mix(in srgb, var(--color-primary) 8%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 25%, transparent),
      inset 0 -1px 0 rgba(0, 0, 0, 0.1);
    will-change: border-radius;
  }

  @media (max-width: 768px) {
    .glass-header {
      backdrop-filter: blur(24px) saturate(160%);
      -webkit-backdrop-filter: blur(24px) saturate(160%);
    }
  }

  .glass-header.scrolled {
    border-radius: 0;
    border-color: transparent;
  }

  .glass-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-primary) 50%, transparent), transparent);
  }

  .email-link-desktop,
  .email-text {
    transition: background 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55), color 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  .name-text {
    transition: opacity 0.4s ease;
  }

  .glass-link-header:hover {
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .glass-icon {
    background: transparent;
    border: 1px solid transparent;
  }

  .glass-icon svg {
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    shape-rendering: geometricPrecision;
  }

  .glass-icon:hover {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .email-link-desktop:hover .glass-icon {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .email-link-desktop:hover .mail-icon,
  .email-link-mobile:hover .mail-icon,
  .glass-icon:hover .mail-icon {
    color: rgb(255 255 255 / 1);
  }
</style>
