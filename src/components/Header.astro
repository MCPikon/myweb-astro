---
import { EMAIL, INSTAGRAM_URL, GITHUB_URL, LINKEDIN_URL } from "@/utils/constants";

import MailIcon from "./icons/Mail.astro"
import InstagramIcon from "./icons/Instagram.astro"
import GitHubIcon from "./icons/GitHub.astro"
import LinkedinIcon from "./icons/Linkedin.astro"
---

<section class="z-50 fixed header-section">
  <nav class="glass-header flex items-center justify-between px-4 py-2 rounded-full nav-content">
    <div class="flex items-center gap-2">
      <a
        aria-label={EMAIL}
        href={"mailto:" + EMAIL}
        class="email-link-mobile flex lg:hidden p-2 rounded-lg glass-icon transition-all"
      >
        <MailIcon class="mail-icon text-white/70 size-5 transition-all" />
      </a>
      <a
        aria-label={EMAIL}
        href={"mailto:" + EMAIL}
        class="email-link-desktop hidden lg:flex flex-row items-center justify-center gap-2 px-3 py-2 rounded-xl glass-link-header transition-all"
      >
        <div class="p-2 rounded-lg glass-icon transition-all flex items-center justify-center">
          <MailIcon class="mail-icon text-white/70 size-5 transition-all" />
        </div>
        <h3 class="text-sm text-white/80 font-medium transition-all email-text">
          {EMAIL}
        </h3>
      </a>
    </div>

    <div class="flex items-center gap-1">
      <a
        aria-label="Instagram"
        target="_blank"
        href={INSTAGRAM_URL}
        class="p-2 rounded-lg glass-icon transition-all"
      >
        <InstagramIcon class="fill-white/70 size-5 transition-all hover:fill-white" />
      </a>
      <a
        aria-label="Github"
        target="_blank"
        href={GITHUB_URL}
        class="p-2 rounded-lg glass-icon transition-all"
      >
        <GitHubIcon class="fill-white/70 size-5 transition-all hover:fill-white" />
      </a>
      <a
        aria-label="Linkedin"
        target="_blank"
        href={LINKEDIN_URL}
        class="p-2 rounded-lg glass-icon transition-all"
      >
        <LinkedinIcon class="fill-white/70 size-5 transition-all hover:fill-white" />
      </a>
    </div>
  </nav>
</section>

<script>
  /** @type {(() => void) | null} */
  let cleanupHeader = null;

  function setupHeader() {
    const headerSection = document.querySelector('.header-section');
    const navContent = document.querySelector('.nav-content');

    if (!headerSection || !navContent) return;

    cleanupHeader?.();

    let lastScrolledState = window.scrollY > 0;
    let ticking = false;

    /** @param {boolean} isScrolled */
    const syncScrolledState = (isScrolled) => {
      if (isScrolled === lastScrolledState) return;

      lastScrolledState = isScrolled;
      headerSection.classList.toggle('scrolled', isScrolled);
      navContent.classList.toggle('scrolled', isScrolled);
    };

    headerSection.classList.toggle('scrolled', lastScrolledState);
    navContent.classList.toggle('scrolled', lastScrolledState);

    const handleScroll = () => {
      if (ticking) return;

      ticking = true;

      window.requestAnimationFrame(() => {
        syncScrolledState(window.scrollY > 0);
        ticking = false;
      });
    };

    window.addEventListener('scroll', handleScroll, { passive: true });

    cleanupHeader = () => {
      window.removeEventListener('scroll', handleScroll);
    };
  }

  setupHeader();
  document.addEventListener('astro:after-swap', setupHeader);
</script>

<style>
  .header-section {
    margin: 0.75rem auto 1.5rem;
    width: min(1200px, calc(100% - 2rem));
    top: 1.25rem;
    left: 50%;
    right: auto;
    transition: width 0.5s cubic-bezier(0.65, 0, 0.35, 1),
      margin 0.5s cubic-bezier(0.65, 0, 0.35, 1),
      top 0.5s cubic-bezier(0.65, 0, 0.35, 1),
      transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
    transform: translateX(-50%);
    will-change: width, top, transform;
  }

  @media (max-width: 768px) {
    .header-section {
      width: calc(100% - 1.5rem);
      margin: 0.5rem auto 1.25rem;
      transition:
        width 0.42s cubic-bezier(0.65, 0, 0.35, 1),
        margin 0.42s cubic-bezier(0.65, 0, 0.35, 1),
        top 0.42s cubic-bezier(0.65, 0, 0.35, 1),
        transform 0.42s cubic-bezier(0.65, 0, 0.35, 1);
      will-change: width, top, transform;
    }
  }

  .header-section.scrolled {
    margin: 0;
    width: 100%;
    top: 0;
    left: 50%;
    right: auto;
    transform: translateX(-50%);
    padding: 0;
  }

  .glass-header {
    width: 100%;
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.3),
      0 0 40px color-mix(in srgb, var(--color-primary) 8%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 25%, transparent),
      inset 0 -1px 0 rgba(0, 0, 0, 0.1);
    position: relative;
    overflow: hidden;
    border-radius: 9999px;
    transition:
      border-radius 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55),
      background 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55),
      border-color 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55),
      box-shadow 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    will-change: border-radius;
  }

  @media (max-width: 768px) {
    .glass-header {
      backdrop-filter: blur(24px) saturate(160%);
      -webkit-backdrop-filter: blur(24px) saturate(160%);
      transition:
        border-radius 0.42s cubic-bezier(0.68, -0.55, 0.265, 1.55),
        background 0.42s cubic-bezier(0.68, -0.55, 0.265, 1.55),
        border-color 0.42s cubic-bezier(0.68, -0.55, 0.265, 1.55),
        box-shadow 0.42s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }
  }

  .glass-header.scrolled {
    border-radius: 0;
    border-color: transparent;
    width: 100%;
    margin: 0 auto;
  }

  .glass-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-primary) 50%, transparent), transparent);
  }

  .email-link-desktop,
  .email-text {
    transition: background 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55), color 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  .name-text {
    transition: opacity 0.4s ease;
  }

  .glass-link-header:hover {
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .glass-icon {
    background: transparent;
    border: 1px solid transparent;
  }

  .glass-icon:hover {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .email-link-desktop:hover .glass-icon {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .email-link-desktop:hover .mail-icon,
  .email-link-mobile:hover .mail-icon,
  .glass-icon:hover .mail-icon {
    color: rgb(255 255 255 / 1);
  }
</style>
