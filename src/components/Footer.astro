---
import InstagramIcon from "./icons/Instagram.astro";
import TwitterIcon from "./icons/Twitter.astro";
import GitHubIcon from "./icons/GitHub.astro";
import LinkedinIcon from "./icons/Linkedin.astro";

import {
  INSTAGRAM_URL,
  TWITTER_URL,
  GITHUB_URL,
  LINKEDIN_URL,
} from "@/utils/constants";

import { getI18N } from "@/i18n";

const currentLocale = Astro.currentLocale ?? "es";
const i18n = getI18N({ currentLocale });
---

<footer>
  <div class="footer-glass">
    <section class="footer-content">
      <div
        class="flex gap-y-6 sm:flex-row flex-col-reverse justify-between py-8"
      >
        <div class="flex flex-col gap-y-6">
          <h1 class="text-primary font-extrabold text-2xl">Javier Picón</h1>
          <p class="text-(--color-text-muted) sm:w-4/6 w-full">
            {i18n.FOOTER_JOB_TITLE}
            <span class="text-(--color-text-muted) opacity-70 italic font-light"
              >(Java/Spring & Gen AI)</span
            >
          </p>
        </div>
        <div class="flex flex-col gap-y-2">
          <h1 class="text-primary text-xl md:text-center pb-1.5 font-bold">
            {i18n.FOOTER_MY_LINKS}
          </h1>
          <div class="footer-links md:gap-0.5">
            <a
              aria-label="Instagram"
              target="_blank"
              href={INSTAGRAM_URL}
              class="footer-link"
            >
              <InstagramIcon class="size-6 transition-all ease-in-out" />
            </a>
            <a
              aria-label="Twitter/X"
              target="_blank"
              href={TWITTER_URL}
              class="footer-link"
            >
              <TwitterIcon class="size-6 transition-all ease-in-out" />
            </a>
            <a
              aria-label="Github"
              target="_blank"
              href={GITHUB_URL}
              class="footer-link"
            >
              <GitHubIcon class="size-6 transition-all ease-in-out" />
            </a>
            <a
              aria-label="Linkedin"
              target="_blank"
              href={LINKEDIN_URL}
              class="footer-link"
            >
              <LinkedinIcon class="size-6 transition-all ease-in-out" />
            </a>
          </div>
        </div>
      </div>
      <hr class="footer-divider" />
      <h1 class="text-secondary text-sm text-center py-4">
        © <span id="year">YEAR</span> - {i18n.FOOTER_MADE_BY_TEXT}<a
          class="font-bold"
          href="/">Javier Picón</a
        >
      </h1>
    </section>
  </div>
</footer>

<script>
  function updateYear() {
    const yearElement = document.getElementById("year");
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear().toString();
    }
  }

  updateYear();

  document.addEventListener("astro:page-load", updateYear);
</script>

<style>
  .footer-glass {
    width: min(1200px, calc(100% - 2rem));
    margin: 3rem auto 0;
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    box-shadow:
      0 16px 48px var(--color-shadow),
      0 0 40px var(--color-glass-shadow),
      inset 0 1px 0 color-mix(in srgb, var(--color-primary) 25%, transparent),
      inset 0 -1px 0 var(--color-glass-highlight);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border-radius: 1.5rem 1.5rem 0 0;
    position: relative;
    overflow: hidden;
  }

  .footer-glass::before {
    content: "";
    position: absolute;
    top: 0;
    left: 12%;
    right: 12%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--color-primary) 50%, transparent),
      transparent
    );
  }

  .footer-content {
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 2rem 1.25rem;
  }

  .footer-divider {
    border: none;
    height: 1px;
    background: var(--color-glass-border);
    opacity: 0.6;
  }

  .footer-links {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .footer-link {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid transparent;
    transition: all 0.45s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  .footer-link:hover {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    box-shadow: 0 4px 12px
      color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .footer-link svg {
    transition:
      color 0.3s ease,
      fill 0.3s ease;
    color: var(--color-text-muted);
    fill: currentColor;
  }

  .footer-link:hover svg {
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .footer-glass {
      width: calc(100% - 1.5rem);
    }

    .footer-content {
      padding: 2rem 1.25rem 1rem;
    }
  }

  @media (max-width: 640px) {
    .footer-glass {
      width: calc(100% - 1rem);
      margin-top: 2.5rem;
    }

    .footer-content {
      padding: 1.75rem 1rem 1rem;
    }
  }
</style>
